<%- include('../partial/header', { activePage }) %>

<section class="blog-post">
  <% if (!blog) { %>
    <div class="card">Blog not found.</div>
  <% } else { %>
    <div class="post-head">
      <h1><%= blog.title %></h1>
      <p class="blog-meta">
        <%= new Date(blog.createdAt).toLocaleDateString() %>
        <% if (blog.categories?.length) { %>
          • <%= blog.categories.join(', ') %>
        <% } %>
      </p>
    </div>

    <% if (blog.coverImageUrl) { %>
      <img class="post-cover" src="<%= blog.coverImageUrl %>" alt="<%= blog.title %>"/>
    <% } %>

    <div class="post-content card">
      <%- blog.contentHtml %>
    </div>

    <% if (relatedBlogs && relatedBlogs.length) { %>
      <section class="related-blogs">
        <h3>Related Blogs</h3>

        <div class="related-list">
          <% relatedBlogs.forEach(rb => { %>
            <article class="related-card card">
              <% if (rb.coverImageUrl) { %>
                <img class="related-cover" src="<%= rb.coverImageUrl %>" alt="<%= rb.title %>" />
              <% } %>

              <div class="related-body">
                <h4><a href="/blogs/<%= rb.slug %>"><%= rb.title %></a></h4>
                <p class="blog-meta">
                  <%= new Date(rb.createdAt).toLocaleDateString() %>
                  <% if (rb.categories?.length) { %>
                    • <span class="blog-tag"><%= rb.categories[0] %></span>
                  <% } %>
                </p>
                <p><%= rb.excerpt || '' %></p>
                <a class="card-btn" href="/blogs/<%= rb.slug %>">Read more →</a>
              </div>
            </article>
          <% }) %>
        </div>
      </section>
    <% } %>

    <a class="card-btn" href="/blogs">← Back to blogs</a>
  <% } %>
</section>

<%- include('../partial/footer') %>