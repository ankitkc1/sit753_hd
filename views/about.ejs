<!doctype html>
<html lang="en" >
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width,initial-scale=1" />
  <title><%= (profile?.name ? `${profile.name} — About` : 'About') %></title>

  <!--load Inter locally if you have it. Otherwise your system-ui fallback will work. -->
   <link rel="stylesheet" href="style.css" />
  <link rel="stylesheet" href="about.css" />
</head>

<body>
  <header>
    <%- include('./partial/nav.ejs') %>
  </header>

  <main class="wrap page">
    <!-- HERO -->
    <section id="about" class="hero">
      <div class="hero__card">
        <div class="hero__media">
        <img class="avatar" src="<%= profile.avatarUrl %>" alt="Profile photo">
          <div class="stamp" aria-hidden="true">
            <div class="stamp__ring"></div>
            <div class="stamp__text">ABOUT • PROFILE •</div>
          </div>
        </div>

        <div class="hero__content">
          <p class="kicker"><%= profile?.kicker || 'Developer • Researcher • Builder' %></p>
          <h1 class="title">
            <%= profile?.headline || (profile?.name ? `Hi, I’m ${profile.name}.` : 'Hi, I’m a developer.') %>
          </h1>
          <p class="lead">
            <%= profile?.intro || 'Write a short, confident intro here. Mention what you build, what you’re known for, and what you’re looking for next.' %>
          </p>

          <div class="chips" aria-label="Highlights">
            <% (profile?.highlights || ['Full-stack', 'Node.js', 'EJS', 'UI polish', 'Research impact']).forEach(function(tag){ %>
              <span class="chip"><%= tag %></span>
            <% }) %>
          </div>

          <div class="hero__meta">
            <div class="meta">
              <span class="meta__label">Location</span>
              <span class="meta__value"><%= profile?.location || 'Melbourne, AU' %></span>
            </div>
            <div class="meta">
              <span class="meta__label">Email</span>
              <span class="meta__value">
                <a class="link" href="mailto:<%= profile?.email || 'hello@example.com' %>">
                  <%= profile?.email || 'hello@example.com' %>
                </a>
              </span>
            </div>
            <div class="meta">
              <span class="meta__label">Website</span>
              <span class="meta__value">
                <% if (profile?.website) { %>
                  <a class="link" href="<%= profile.website %>" target="_blank" rel="noreferrer"><%= profile.websiteLabel || 'Visit' %></a>
                <% } else { %>
                  <span class="muted">your-site.com</span>
                <% } %>
              </span>
            </div>
          </div>

          <div class="hero__cta">
            <button class="btn" id="copyEmail" type="button" data-email="<%= profile?.email || 'hello@example.com' %>">
              Copy email
            </button>

            <% if (profile?.cvUrl) { %>
              <a class="btn btn--ghost" href="<%= profile.cvUrl %>" target="_blank" rel="noreferrer">Download CV</a>
            <% } else { %>
              <a class="btn btn--ghost" href="#" aria-disabled="true" onclick="return false;">Download CV</a>
            <% } %>
          </div>

          <p class="fine muted">
            <span class="pulse" aria-hidden="true"></span>
            <%= profile?.statusLine || 'Open to collaborations & interesting problems.' %>
          </p>
        </div>
      </div>
    </section>

    <!-- STATS (COUNT UP) -->
    <section id="research" class="section">
      <div class="section__head">
        <h2 class="h2">Research & Impact</h2>
        <p class="sub">
          Numbers that animate when the section becomes visible — clean, credible, and satisfying.
        </p>
      </div>

      <div class="stats" data-animate="counters">
        <% (stats || [
          { label: 'Publications', value: 12, suffix: '+', note: 'Peer-reviewed' },
          { label: 'Reviewed papers', value: 37, suffix: '+', note: 'Journal / conference' },
          { label: 'Total citations', value: 420, suffix: '+', note: 'Google Scholar' },
          { label: 'h-index', value: 9, suffix: '', note: 'Current' },
          { label: 'Projects shipped', value: 28, suffix: '+', note: 'Production builds' },
          { label: 'Talks / workshops', value: 15, suffix: '+', note: 'Invited & community' }
        ]).forEach(function(s){ %>

          <article class="stat">
            <div class="stat__top">
              <div class="stat__label"><%= s.label %></div>
              <div class="stat__value">
                <span
                  class="count"
                  data-count="<%= s.value %>"
                  data-suffix="<%= s.suffix || '' %>"
                  aria-label="<%= `${s.label}: ${s.value}${s.suffix || ''}` %>"
                ><%= s.value %><%= s.suffix || '' %></span>
              </div>
            </div>
            <div class="stat__note muted"><%= s.note || '' %></div>
            <div class="stat__bar" aria-hidden="true"></div>
          </article>

        <% }) %>
      </div>

      <div class="impact">
        <div class="impact__card">
          <h3 class="h3">Impact snapshot</h3>
          <p class="muted">
            Add your sources (Google Scholar, Scopus, ORCID), and this section becomes your “credibility engine”.
          </p>

          <div class="impact__grid">
            <div class="ring" data-ring="<%= impact?.citationGrowth || 68 %>">
              <div class="ring__inner">
                <div class="ring__value"><%= impact?.citationGrowth || 68 %>%</div>
                <div class="ring__label muted">Citation growth</div>
              </div>
            </div>

            <div class="impact__list">
              <div class="kv">
                <span class="kv__k muted">ORCID</span>
                <span class="kv__v"><%= impact?.orcid || '0000-0000-0000-0000' %></span>
              </div>
              <div class="kv">
                <span class="kv__k muted">Research areas</span>
                <span class="kv__v"><%= (impact?.areas || ['HCI', 'Systems', 'Health tech']).join(' • ') %></span>
              </div>
              <div class="kv">
                <span class="kv__k muted">Last updated</span>
                <span class="kv__v"><%= impact?.lastUpdated || 'This month' %></span>
              </div>
            </div>
          </div>
        </div>

        <div class="impact__card impact__card--quiet">
          <h3 class="h3">Signature strength</h3>
          <p class="muted">
            A simple promise you keep: fast delivery, clean architecture, and sharp UI details.
          </p>
          <ul class="ticks">
            <li>Readable codebase (naming, structure, comments)</li>
            <li>Accessible UI (ARIA, keyboard, reduced motion)</li>
            <li>Performance-first (lazy media, minimal JS)</li>
            <li>Production habits (logs, errors, edge cases)</li>
          </ul>
        </div>
      </div>
    </section>

    <!-- SKILLS -->
    <section id="skills" class="section">
      <div class="section__head">
        <h2 class="h2">Skills</h2>
        <p class="sub">Animated progress bars that only play when visible (and respect reduced motion).</p>
      </div>

      <div class="skills" data-animate="skills">
        <% (skills || [
          { group: 'Frontend', items: [
            { name: 'HTML/CSS', level: 92, note: 'Responsive, accessible UI' },
            { name: 'JavaScript', level: 88, note: 'Modern patterns, clean DOM work' },
            { name: 'UI Polish', level: 90, note: 'Micro-interactions & layout' }
          ]},
          { group: 'Backend', items: [
            { name: 'Node.js', level: 86, note: 'Express, APIs, auth' },
            { name: 'Databases', level: 78, note: 'SQL, indexing, schemas' },
            { name: 'Testing', level: 74, note: 'Unit + integration' }
          ]},
          { group: 'Research', items: [
            { name: 'Scientific writing', level: 82, note: 'Clarity + structure' },
            { name: 'Peer review', level: 80, note: 'Method & rigor' },
            { name: 'Data analysis', level: 76, note: 'Clean, reproducible' }
          ]}
        ]).forEach(function(group){ %>

          <section class="skillgroup" aria-label="<%= group.group %>">
            <h3 class="h3"><%= group.group %></h3>

            <div class="skilllist">
              <% group.items.forEach(function(item){ %>
                <div class="skill">
                  <div class="skill__row">
                    <div class="skill__name"><%= item.name %></div>
                    <div class="skill__pct muted"><span class="pct" data-pct="<%= item.level %>"><%= item.level %></span>%</div>
                  </div>

                  <div
                    class="bar"
                    role="progressbar"
                    aria-label="<%= item.name %>"
                    aria-valuemin="0"
                    aria-valuemax="100"
                    aria-valuenow="<%= item.level %>"
                    data-level="<%= item.level %>"
                  >
                    <div class="bar__fill"></div>
                  </div>

                  <% if (item.note) { %>
                    <div class="skill__note muted"><%= item.note %></div>
                  <% } %>
                </div>
              <% }) %>
            </div>
          </section>

        <% }) %>
      </div>
    </section>

    <!-- EDUCATION -->
    <section id="education" class="section">
      <div class="section__head">
        <h2 class="h2">Education</h2>
        <p class="sub">A timeline layout that looks premium and reads fast.</p>
      </div>

      <div class="timeline">
        <% (education || [
          {
            degree: 'Bachelor of Nursing',
            school: 'Your University',
            years: '2024 — 2028',
            grade: 'GPA: 6.2/7 (HD focus)',
            //details: ['Clinical placements', 'Evidence-based practice', 'Leadership & communication']
          },
          {
            degree: 'Diploma / Certificate',
            school: 'Your Institute',
            years: '2023 — 2024',
            grade: 'Distinction',
            //details: ['Community services', 'Care planning', 'Professional practice']
          }
        ]).forEach(function(ed){ %>

          <article class="titem">
            <div class="titem__dot" aria-hidden="true"></div>
            <div class="titem__card">
              <div class="titem__top">
                <h3 class="h3"><%= ed.degree %></h3>
                <div class="titem__years muted"><%= ed.years %></div>
              </div>
              <div class="titem__school"><%= ed.school %></div>
              <div class="titem__grade muted"><%= ed.grade %></div>

              <% if (ed.details && ed.details.length) { %>
                <ul class="bullets">
                  <% ed.details.forEach(function(d){ %>
                    <li><%= d %></li>
                  <% }) %>
                </ul>
              <% } %>
            </div>
          </article>

        <% }) %>
      </div>
    </section>
    

<%- include('./partial/footer') %>
  </main>

  <script defer src="about.js"></script>
</body>
</html>